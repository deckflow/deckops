{
  "name": "deckops-monorepo",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --sort build",
    "dev": "pnpm --filter deckops dev",
    "test": "pnpm -r --sort test",
    "test:unit": "pnpm -r --sort test:unit",
    "test:e2e": "pnpm --filter deckops test:e2e",
    "typecheck": "pnpm -r --sort typecheck",
    "lint": "pnpm -r --sort lint",
    "format": "prettier --write 'apps/**/*.ts' 'sdks/**/*.ts'",
    "install:global": "pnpm --filter deckops... build && npm install -g ./apps/node-cli",
    "release:check": "pnpm typecheck && pnpm test && pnpm build",
    "release:sdk": "pnpm --filter @deckops/sdk publish --access public",
    "release:cli": "pnpm --filter deckops publish --access public",
    "release": "pnpm release:check && pnpm release:sdk && pnpm release:cli"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "axios-mock-adapter": "^1.22.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
