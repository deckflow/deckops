{
  "name": "deckops",
  "version": "0.2.2",
  "description": "Deck operate CLI tool - File processing and conversion tools",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "deckops": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "deckflow",
    "file-processing",
    "converter",
    "tools"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/deckflow/deckops.git"
  },
  "homepage": "https://github.com/deckflow/deckops#readme",
  "bugs": {
    "url": "https://github.com/deckflow/deckops/issues"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "axios-retry": "^4.0.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "eventsource-parser": "^1.1.0",
    "form-data": "^4.0.5",
    "inquirer": "^9.2.0",
    "open": "^11.0.0",
    "ora": "^7.0.0",
    "p-limit": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "axios-mock-adapter": "^1.22.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
